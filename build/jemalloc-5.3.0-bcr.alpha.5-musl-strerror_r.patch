diff --git a/src/malloc_io.c b/src/malloc_io.c
--- a/src/malloc_io.c
+++ b/src/malloc_io.c
@@ -96,7 +96,11 @@
 	FormatMessageA(FORMAT_MESSAGE_FROM_SYSTEM, NULL, err, 0,
 	    (LPSTR)buf, (DWORD)buflen, NULL);
 	return 0;
-#elif defined(JEMALLOC_STRERROR_R_RETURNS_CHAR_WITH_GNU_SOURCE) && defined(_GNU_SOURCE)
+/*
+ * musl keeps the POSIX int-returning strerror_r even with _GNU_SOURCE.
+ * The char * variant is glibc-specific.
+ */
+#elif defined(JEMALLOC_STRERROR_R_RETURNS_CHAR_WITH_GNU_SOURCE) && defined(_GNU_SOURCE) && defined(__GLIBC__)
 	char *b = strerror_r(err, buf, buflen);
 	if (b != buf) {
 		strncpy(buf, b, buflen);